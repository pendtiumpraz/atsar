# ─────────────────────────────────────────────────────────────────────
#  Athar — Environment Variables Template
#  Copy this file to .env.local and fill with real values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────

# ─── Database (Neon Postgres) ───────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ─── Redis (Upstash) ────────────────────────────────────────────────
REDIS_URL=rediss://default:TOKEN@HOST:6379
KV_REST_API_URL=https://HOST.upstash.io
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── QStash (Upstash serverless queue — replaces BullMQ for Vercel) ─
QSTASH_URL=https://qstash-us-east-1.upstash.io
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ─── Auth (better-auth) ─────────────────────────────────────────────
BETTER_AUTH_SECRET=        # 64 random chars (openssl rand -hex 32)
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ─── AI (encrypted in DB, master key here) ──────────────────────────
AI_MASTER_KEY=              # 64 chars (for AES-256-GCM encrypt provider keys)

# Seed key — used by seeder 008 to insert initial DeepSeek provider key
SEED_DEEPSEEK_API_KEY=

# ─── Storage (S3-compatible: MinIO / R2 / Cloudflare R2) ────────────
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=athar-storage
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# ─── Email (Resend) ─────────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=noreply@athar.id

# ─── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=Athar
NODE_ENV=development
LOG_LEVEL=info

# ─── Worker ─────────────────────────────────────────────────────────
WORKER_CONCURRENCY_PDF=1
WORKER_CONCURRENCY_RESEARCH=2

# ─── Admin contact (rendered on subscription expired page) ──────────
ADMIN_NAME=Galih
ADMIN_WA_NUMBER=6281319504441

# ─── Initial admin seed (used only by seeder 016_admin_user) ────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Galih

# ─── Observability ──────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
