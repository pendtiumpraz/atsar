# ─────────────────────────────────────────────────────────
#  SECRETS — NEVER COMMIT
# ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
secrets/
.secrets

# ─────────────────────────────────────────────────────────
#  Dependencies & Build
# ─────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnp/
.pnp.js

# Next.js
.next/
out/
.vercel/

# Turborepo
.turbo/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────
#  Logs & runtime
# ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────
#  Coverage & test
# ─────────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ─────────────────────────────────────────────────────────
#  IDE
# ─────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────
#  Claude Code — per-user, do not commit
# ─────────────────────────────────────────────────────────
.claude/settings.local.json

# ─────────────────────────────────────────────────────────
#  OS
# ─────────────────────────────────────────────────────────
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────────────────
#  Drizzle migrations metadata (commit migrations themselves)
# ─────────────────────────────────────────────────────────
.drizzle/

# ─────────────────────────────────────────────────────────
#  Storage / uploads (local dev only)
# ─────────────────────────────────────────────────────────
# Leading slash anchors to repo root — without it, glob matches any
# directory named `uploads/` and unintentionally ignores source code
# like `apps/web/lib/server/uploads/`.
/storage/
/uploads/
/public/uploads/
/public/fonts/cache/

# ─────────────────────────────────────────────────────────
#  PDF generator output (local)
# ─────────────────────────────────────────────────────────
generated/

# ─────────────────────────────────────────────────────────
#  Misc
# ─────────────────────────────────────────────────────────
.cache/
tmp/
temp/
