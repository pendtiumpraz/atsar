{
  "name": "@athar/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "seed:dev": "tsx src/seed.ts --dev",
    "reset": "tsx src/reset.ts",
    "studio": "drizzle-kit studio",
    "check": "tsx src/check.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@athar/shared": "workspace:*",
    "@neondatabase/serverless": "^0.10.4",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.38.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
